---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageHero from '../components/ui/PageHero.astro'; import Breadcrumbs from '../components/ui/Breadcrumbs.astro'; import Section from '../components/ui/Section.astro'; import CTASection from '../components/ui/CTASection.astro'; import ScorecardTable from '../components/golf/ScorecardTable.astro'; import {course} from '../data/course'; import {business} from '../data/business'; import {pageSeo} from '../data/seo';
---
<BaseLayout {...pageSeo.course}><Breadcrumbs items={[{label:'Home',href:'/'},{label:'Course'}]}/><PageHero eyebrow="The course" title="Interesting choices. Honest golf." intro="Our 18-hole layout moves through open meadows, mature cedar stands, and a rolling ridge—with a tee that fits your day."><a class="btn-primary" href={business.bookingUrl}>Book a tee time</a></PageHero><Section eyebrow="Scorecard" title="Choose the right distance." intro="A comfortable tee creates more chances to hit greens and keeps the round moving."><ScorecardTable/></Section><Section tone="green" eyebrow="Course details" title="Built for a round you want to replay."><div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">{course.stats.map(s=><div><p class="font-serif text-5xl text-gold">{s.value}</p><p class="mt-2 text-white/65">{s.label}</p></div>)}</div></Section><Section eyebrow="Hole by hole" title="A quick look before you play."><div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">{course.holes.map(h=><article class="surface p-6"><div class="flex items-start justify-between"><p class="eyebrow">Hole {h.number}</p><p class="text-sm font-bold text-fairway">Par {h.par} · {h.yards} yds</p></div><h3 class="mt-5 text-2xl">{h.name}</h3><p class="mt-3 text-sm leading-6 text-charcoal/65">{h.tip}</p></article>)}</div></Section><Section tone="cream" eyebrow="Before you play" title="Course policies"><ul class="grid gap-3 md:grid-cols-2">{course.policies.map(p=><li class="flex gap-3 rounded-xl bg-white p-4"><span class="text-gold">◆</span>{p}</li>)}</ul></Section><Section eyebrow="Course gallery" title="The view changes with the round." intro="Replace these visual placeholders with optimized WebP or AVIF course photography in public/images."><div class="grid gap-4 md:grid-cols-3"><div class="topo min-h-72 rounded-2xl bg-forest"></div><div class="topo min-h-72 rounded-2xl bg-fairway"></div><div class="topo min-h-72 rounded-2xl bg-gold/60"></div></div></Section><CTASection title="See it for yourself." body="Check availability and choose the tee that makes the course yours." primaryLabel="Book a tee time" primaryHref={business.bookingUrl}/></BaseLayout>
