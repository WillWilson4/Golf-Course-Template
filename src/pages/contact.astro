---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import ContactCard from "../components/ui/ContactCard.astro";
import FormField from "../components/ui/FormField.astro";
import HoursCard from "../components/ui/HoursCard.astro";
import PageHero from "../components/ui/PageHero.astro";
import Section from "../components/ui/Section.astro";
import { business } from "../data/business";
import { forms } from "../data/forms";
import { contactContent } from "../data/pageContent";
import { pageSeo } from "../data/seo";
---

<BaseLayout {...pageSeo.contact}>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Contact" }]} />
  <PageHero {...contactContent.hero}>
    <a class="btn-primary" href={business.phoneHref}>Call {business.phone}</a>
    <a class="btn-secondary" href={business.directionsUrl}>Get directions</a>
  </PageHero>

  <Section {...contactContent.visit}>
    <div class="grid gap-6 lg:grid-cols-3">
      <ContactCard variant="address" />
      <ContactCard variant="contact" />
      <HoursCard />
    </div>
  </Section>

  <Section
    tone="cream"
    eyebrow={contactContent.map.eyebrow}
    title={contactContent.map.title}
  >
    <div
      class="topo grid min-h-80 place-items-center rounded-2xl bg-mist p-8 text-center"
      role="img"
      aria-label={contactContent.map.label}
    >
      <div>
        <p class="font-serif text-2xl text-forest">
          {contactContent.map.heading}
        </p>
        <p class="mt-2 text-sm text-charcoal/60">{contactContent.map.body}</p>
        <a class="btn-secondary mt-6" href={business.directionsUrl}
          >Open in maps</a
        >
      </div>
    </div>
  </Section>

  <Section
    eyebrow={forms.contact.eyebrow}
    title={forms.contact.title}
    intro={forms.contact.intro}
    narrow
  >
    <form class="grid gap-5" aria-label="Contact form">
      <FormField
        label="Name"
        name="contact-name"
        autocomplete="name"
        required
      />
      <FormField
        label="Email"
        name="contact-email"
        type="email"
        autocomplete="email"
        required
      />
      <FormField
        label="Topic"
        name="contact-topic"
        kind="select"
        options={["General question", "Tee times", "Events", "Membership"]}
      />
      <FormField
        label="Message"
        name="contact-message"
        kind="textarea"
        required
      />
      <button
        class="btn-primary justify-self-start opacity-70"
        type="button"
        disabled
      >
        {forms.contact.buttonLabel}
      </button>
      <p class="text-sm text-charcoal/60">{forms.helperText}</p>
    </form>
  </Section>
</BaseLayout>
