---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageHero from '../components/ui/PageHero.astro'; import Breadcrumbs from '../components/ui/Breadcrumbs.astro'; import Section from '../components/ui/Section.astro'; import {business} from '../data/business'; import {pageSeo} from '../data/seo';
---
<BaseLayout {...pageSeo.contact}><Breadcrumbs items={[{label:'Home',href:'/'},{label:'Contact'}]}/><PageHero eyebrow="Contact & directions" title="Let’s make the next step easy." intro="Call for today’s course conditions and tee-time help, or email for events, memberships, and general questions."><a class="btn-primary" href={business.phoneHref}>Call {business.phone}</a><a class="btn-secondary" href={business.directionsUrl}>Get directions</a></PageHero><Section eyebrow="Visit Cedar Ridge" title="Everything you need before you go."><div class="grid gap-6 lg:grid-cols-3"><article class="surface p-7"><p class="eyebrow">Address</p><address class="mt-6 not-italic leading-7">{business.address.street}<br/>{business.address.city}, {business.address.region} {business.address.postalCode}</address><a class="mt-6 inline-block font-bold text-fairway" href={business.directionsUrl}>Open directions →</a></article><article class="surface p-7"><p class="eyebrow">Contact</p><p class="mt-6 leading-8"><a href={business.phoneHref}>{business.phone}</a><br/><a href={`mailto:${business.email}`}>{business.email}</a></p></article><article class="surface p-7"><p class="eyebrow">Hours</p><div class="mt-6 space-y-4">{business.hours.map(h=><div><p class="font-bold">{h.days}</p><p class="text-sm text-charcoal/60">{h.times}</p></div>)}</div></article></div></Section><Section tone="cream" eyebrow="Find us" title="Just outside Cedar Ridge."><div class="topo grid min-h-80 place-items-center rounded-2xl bg-mist p-8 text-center"><div><p class="font-serif text-2xl text-forest">Interactive map placeholder</p><p class="mt-2 text-sm text-charcoal/60">Replace with a privacy-conscious map embed or static map image.</p><a class="btn-secondary mt-6" href={business.directionsUrl}>Open in maps</a></div></div></Section><Section eyebrow="Send a note" title="How can we help?" intro="This is a static form UI placeholder. Connect a form endpoint before launch." narrow><form class="grid gap-5"><label class="grid gap-2 font-bold">Name<input class="rounded-xl border border-forest/20 bg-white p-3 font-normal" name="name" autocomplete="name"/></label><label class="grid gap-2 font-bold">Email<input class="rounded-xl border border-forest/20 bg-white p-3 font-normal" name="email" type="email" autocomplete="email"/></label><label class="grid gap-2 font-bold">Topic<select class="rounded-xl border border-forest/20 bg-white p-3 font-normal" name="topic"><option>General question</option><option>Tee times</option><option>Events</option><option>Membership</option></select></label><label class="grid gap-2 font-bold">Message<textarea class="min-h-36 rounded-xl border border-forest/20 bg-white p-3 font-normal" name="message"></textarea></label><button class="btn-primary justify-self-start" type="button">Prepare message</button><p class="text-xs text-charcoal/50">Demo only—this button does not submit data.</p></form></Section></BaseLayout>
