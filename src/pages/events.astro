---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import EventCard from "../components/ui/EventCard.astro";
import FormField from "../components/ui/FormField.astro";
import PageHero from "../components/ui/PageHero.astro";
import Section from "../components/ui/Section.astro";
import { eventPlanningSteps, events } from "../data/events";
import { forms } from "../data/forms";
import { pageSeo } from "../data/seo";
---

<BaseLayout {...pageSeo.events}>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Events" }]} />
  <PageHero
    eyebrow="Outings & events"
    title="A plan your group can enjoy."
    intro="From the first planning call to the last scorecard, we keep the logistics clear and the day moving."
  >
    <a class="btn-primary" href="#inquiry">Start an inquiry</a>
  </PageHero>

  <Section eyebrow="Ways to gather" title="Golf, clubhouse, or both.">
    <div class="grid gap-6 md:grid-cols-2">
      {events.map((event, index) => <EventCard {event} {index} />)}
    </div>
  </Section>

  <Section
    tone="green"
    eyebrow="Planning flow"
    title="Four steps to a clear event plan."
  >
    <ol class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        eventPlanningSteps.map((step, index) => (
          <li class="border-t border-white/20 pt-5">
            <span class="text-sm font-bold text-gold">0{index + 1}</span>
            <h3 class="mt-4 text-2xl text-white">{step.title}</h3>
            <p class="mt-3 text-sm leading-6 text-white/65">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </Section>

  <Section
    id="inquiry"
    eyebrow={forms.event.eyebrow}
    title={forms.event.title}
    intro={forms.event.intro}
    narrow
  >
    <form class="grid gap-5" aria-label="Event inquiry form">
      <FormField label="Name" name="event-name" autocomplete="name" required />
      <FormField
        label="Email"
        name="event-email"
        type="email"
        autocomplete="email"
        required
      />
      <FormField
        label="Event type"
        name="event-type"
        kind="select"
        options={["Golf outing", "Tournament", "League", "Private event"]}
      />
      <FormField
        label="Group size and details"
        name="event-details"
        kind="textarea"
        required
      />
      <button
        class="btn-primary justify-self-start opacity-70"
        type="button"
        disabled
      >
        {forms.event.buttonLabel}
      </button>
      <p class="text-sm text-charcoal/60">{forms.helperText}</p>
    </form>
  </Section>
</BaseLayout>
