---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageHero from '../components/ui/PageHero.astro'; import Breadcrumbs from '../components/ui/Breadcrumbs.astro'; import Section from '../components/ui/Section.astro'; import {events} from '../data/events'; import {pageSeo} from '../data/seo';
---
<BaseLayout {...pageSeo.events}><Breadcrumbs items={[{label:'Home',href:'/'},{label:'Events'}]}/><PageHero eyebrow="Outings & events" title="A plan your group can enjoy." intro="From the first planning call to the last scorecard, we keep the logistics clear and the day moving."><a class="btn-primary" href="#inquiry">Start an inquiry</a></PageHero><Section eyebrow="Ways to gather" title="Golf, clubhouse, or both."><div class="grid gap-6 md:grid-cols-2">{events.map((e,i)=><article class="surface p-7"><p class="eyebrow">{e.tag}</p><h2 class="mt-8 text-3xl">{e.title}</h2><p class="mt-3 leading-7 text-charcoal/65">{e.description}</p><p class="mt-8 text-sm font-bold text-fairway">{String(i+1).padStart(2,'0')} / 04</p></article>)}</div></Section><Section tone="green" eyebrow="What we can handle" title="The pieces of a smooth event."><div class="grid gap-6 md:grid-cols-3">{['Golf & carts','Scoring & contests','Food & gathering'].map((t,i)=><div class="border-t border-white/20 pt-5"><h3 class="text-2xl text-white">{t}</h3><p class="mt-3 text-sm leading-6 text-white/65">{['Shotgun or tee-time starts, cart staging, and player communication.','Scorecards, proximity contests, results, and a clear run of show.','Boxed meals, turn service, buffet options, and clubhouse space.'][i]}</p></div>)}</div></Section><Section id="inquiry" eyebrow="Event inquiry" title="Tell us what you are planning." intro="This form is a static UI placeholder. Connect it to your preferred form service before launch." narrow><form class="grid gap-5" aria-label="Event inquiry form"><label class="grid gap-2 font-bold">Name<input class="rounded-xl border border-forest/20 bg-white p-3 font-normal" name="name" autocomplete="name"/></label><label class="grid gap-2 font-bold">Email<input class="rounded-xl border border-forest/20 bg-white p-3 font-normal" type="email" name="email" autocomplete="email"/></label><label class="grid gap-2 font-bold">Event type<select class="rounded-xl border border-forest/20 bg-white p-3 font-normal" name="type"><option>Golf outing</option><option>Tournament</option><option>League</option><option>Private event</option></select></label><label class="grid gap-2 font-bold">Group size and details<textarea class="min-h-32 rounded-xl border border-forest/20 bg-white p-3 font-normal" name="details"></textarea></label><button class="btn-primary justify-self-start" type="button">Prepare inquiry</button><p class="text-xs text-charcoal/50">Demo only—this button does not submit data.</p></form></Section></BaseLayout>
