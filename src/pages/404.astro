---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/ui/PageHero.astro";
import Section from "../components/ui/Section.astro";
import { business } from "../data/business";
import { utilitySeo } from "../data/seo";

const links = [
  { label: "Book a tee time", href: business.bookingUrl },
  { label: "Explore the course", href: "/course" },
  { label: "Plan an event", href: "/events" },
  { label: "View the menu", href: "/menu" },
  { label: "Contact the golf shop", href: "/contact" },
];
---

<BaseLayout {...utilitySeo.notFound} robots="noindex, follow">
  <PageHero
    eyebrow="404"
    title="That page is out of bounds."
    intro="The link may be old, or the page may have moved. We can get you back into play."
  >
    <a class="btn-primary" href="/">Return home</a>
    <a class="btn-secondary" href={business.bookingUrl}>Book a tee time</a>
  </PageHero>
  <Section eyebrow="Keep exploring" title="Where would you like to go?">
    <nav
      class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3"
      aria-label="Helpful links"
    >
      {
        links.map((link) => (
          <a
            class="surface flex min-h-20 items-center justify-between gap-4 p-5 font-bold text-fairway transition-colors hover:bg-cream"
            href={link.href}
          >
            {link.label} <span aria-hidden="true">&rarr;</span>
          </a>
        ))
      }
    </nav>
  </Section>
</BaseLayout>
