---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageHero from '../components/ui/PageHero.astro'; import Breadcrumbs from '../components/ui/Breadcrumbs.astro'; import Section from '../components/ui/Section.astro'; import FAQBlock from '../components/ui/FAQBlock.astro'; import RatesTable from '../components/golf/RatesTable.astro'; import StructuredData from '../components/seo/StructuredData.astro'; import {business} from '../data/business'; import {rateNotes} from '../data/rates'; import {pageSeo} from '../data/seo';
const faqs=[{question:'How far ahead can I book?',answer:'Public tee times open seven days in advance. Full Golf members receive a 14-day booking window.'},{question:'Are carts included?',answer:'Walking and riding prices are shown separately. Riding prices include a shared cart seat.'},{question:'What is the cancellation policy?',answer:'Please cancel or adjust the group at least 24 hours ahead. Late cancellations may be charged.'},{question:'Can I book a single player?',answer:'Yes. Single players may join an existing group where space is available.'}];
---
<BaseLayout {...pageSeo.teeTimes}><StructuredData data={{'@context':'https://schema.org','@type':'FAQPage',mainEntity:faqs.map(f=>({'@type':'Question',name:f.question,acceptedAnswer:{'@type':'Answer',text:f.answer}}))}}/><Breadcrumbs items={[{label:'Home',href:'/'},{label:'Tee times'}]}/><PageHero eyebrow="Tee times" title="Pick a time. Bring your game." intro="Clear public rates, easy online booking, and a golf shop ready to help with same-day questions."><a class="btn-primary" href={business.bookingUrl}>Book online</a><a class="btn-secondary" href={business.phoneHref}>Call {business.phone}</a></PageHero><Section eyebrow="2026 public rates" title="Simple rates, no hidden surprises."><RatesTable/><ul class="mt-6 grid gap-2 text-sm text-charcoal/60 md:grid-cols-2">{rateNotes.map(n=><li>• {n}</li>)}</ul></Section><Section tone="cream" eyebrow="Good to know" title="Tee-time questions"><FAQBlock items={faqs}/></Section></BaseLayout>
