---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageHero from '../components/ui/PageHero.astro'; import Breadcrumbs from '../components/ui/Breadcrumbs.astro'; import Section from '../components/ui/Section.astro'; import CTASection from '../components/ui/CTASection.astro'; import {activities} from '../data/activities'; import {business} from '../data/business'; import {pageSeo} from '../data/seo';
---
<BaseLayout {...pageSeo.activities}><Breadcrumbs items={[{label:'Home',href:'/'},{label:'Activities'}]}/><PageHero eyebrow="More ways to play" title="Practice, learn, and keep golf going." intro="A useful range, local instruction, junior programs, winter simulators, and a golf shop that can help."><a class="btn-primary" href={business.phoneHref}>Ask about availability</a></PageHero><Section eyebrow="Around the club" title="Build the game you want."><div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">{activities.map((a,i)=><article class="surface flex min-h-64 flex-col p-7"><p class="eyebrow">{String(i+1).padStart(2,'0')}</p><h2 class="mt-8 text-3xl">{a.title}</h2><p class="mt-3 leading-7 text-charcoal/65">{a.description}</p><p class="mt-auto pt-8 text-sm font-bold text-fairway">{a.meta}</p></article>)}</div></Section><CTASection title="Have a practice question?" body="Call the golf shop for range conditions, lesson referrals, clinic dates, or simulator times." primaryLabel={`Call ${business.phone}`} primaryHref={business.phoneHref}/></BaseLayout>
