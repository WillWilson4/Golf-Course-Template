---
import BaseLayout from "../layouts/BaseLayout.astro";
import ActivityCard from "../components/ui/ActivityCard.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import CTASection from "../components/ui/CTASection.astro";
import PageHero from "../components/ui/PageHero.astro";
import Section from "../components/ui/Section.astro";
import { activities } from "../data/activities";
import { business } from "../data/business";
import { pageSeo } from "../data/seo";
---

<BaseLayout {...pageSeo.activities}>
  <Breadcrumbs
    items={[{ label: "Home", href: "/" }, { label: "Activities" }]}
  />
  <PageHero
    eyebrow="More ways to play"
    title="Practice, learn, and keep golf going."
    intro="A useful range, local instruction, junior programs, winter simulators, and a golf shop that can help."
  >
    <a class="btn-primary" href={business.phoneHref}>Ask about availability</a>
  </PageHero>
  <Section eyebrow="Around the club" title="Build the game you want.">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {activities.map((activity, index) => <ActivityCard {activity} {index} />)}
    </div>
  </Section>
  <CTASection
    title="Have a practice question?"
    body="Call or email the golf shop for range conditions, lesson referrals, clinic dates, or simulator times."
    primaryLabel={`Call ${business.phone}`}
    primaryHref={business.phoneHref}
    secondaryLabel="Email the golf shop"
    secondaryHref={`mailto:${business.email}?subject=Lessons and clinics`}
  />
</BaseLayout>
