---
import BaseLayout from '../layouts/BaseLayout.astro'; import Section from '../components/ui/Section.astro'; import CTASection from '../components/ui/CTASection.astro'; import {business} from '../data/business'; import {course} from '../data/course'; import {pageSeo} from '../data/seo';
const cards=[{title:'The course',body:'A fair, engaging 18-hole layout with four sets of tees.',href:'/course',number:'01'},{title:'Events & outings',body:'Practical group packages, scoring support, and clubhouse meals.',href:'/events',number:'02'},{title:'Clubhouse menu',body:'Food and drinks for the turn, the table, or a casual visit.',href:'/menu',number:'03'},{title:'Memberships',body:'Straightforward options for regular local golfers.',href:'/memberships',number:'04'}];
---
<BaseLayout {...pageSeo.home}>
 <section class="relative overflow-hidden bg-forest px-6 py-20 text-white md:py-32"><div class="topo absolute inset-0 opacity-50"></div><div class="relative mx-auto max-w-7xl"><p class="eyebrow text-gold">Cedar Ridge, Wisconsin</p><h1 class="mt-5 max-w-4xl text-6xl leading-[.98] text-white md:text-8xl">Make a good day of it.</h1><p class="mt-7 max-w-2xl text-xl leading-8 text-white/70">{business.tagline}</p><div class="mt-9 flex flex-wrap gap-3"><a class="btn-primary" href={business.bookingUrl}>Book a tee time</a><a class="btn border border-white/50 text-white hover:bg-white hover:text-forest" href="/events">Plan an outing</a></div></div></section>
 <aside class="bg-gold px-6 py-4 text-charcoal"><div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-2 text-sm"><p><strong>{course.status.label}</strong> <span class="mx-2 opacity-40">|</span> {course.status.detail}</p><a class="font-bold underline underline-offset-4" href={business.phoneHref}>Call the golf shop</a></div></aside>
 <Section eyebrow="Start here" title="Golf that fits the day." intro="Come for a quick nine, a regular league night, a weekend round, or a well-run group event."><div class="grid gap-px overflow-hidden rounded-2xl bg-forest/10 md:grid-cols-2 xl:grid-cols-4">{cards.map(card=><a href={card.href} class="group bg-white p-7 hover:bg-cream"><span class="text-xs font-bold text-gold">{card.number}</span><h2 class="mt-12 text-2xl">{card.title}</h2><p class="mt-3 text-sm leading-6 text-charcoal/65">{card.body}</p><span class="mt-6 inline-block font-bold text-fairway group-hover:translate-x-1">Explore →</span></a>)}</div></Section>
 <Section tone="green" eyebrow="By the numbers" title="A course with room to choose your game."><div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">{course.stats.map(stat=><div class="border-t border-white/20 pt-5"><p class="font-serif text-5xl text-gold">{stat.value}</p><p class="mt-2 text-sm text-white/65">{stat.label}</p></div>)}</div></Section>
 <Section tone="cream" eyebrow="Groups welcome" title="Outings without the guesswork." intro="We help organizers shape the golf, food, scoring, and schedule around the group—not the other way around."><a class="btn-primary" href="/events">Explore event options</a></Section>
 <Section eyebrow="The clubhouse" title="Good food. Cold drinks. No ceremony required." intro="Stop in before the round, grab something at the turn, or settle in afterward. Our menu stays familiar, useful, and seasonal."><div class="grid gap-6 md:grid-cols-[1.4fr_.6fr]"><div class="topo min-h-72 rounded-2xl bg-forest p-8 text-white"><p class="eyebrow text-gold">This week</p><p class="mt-6 max-w-md font-serif text-4xl">Friday fish fry, league-night burgers, and breakfast sandwiches on the weekend.</p></div><div class="surface flex flex-col justify-between p-8"><div><p class="eyebrow">Kitchen hours</p><p class="mt-5 text-2xl font-semibold">Daily<br/>11 AM–8 PM</p></div><a class="btn-secondary mt-8" href="/menu">View the menu</a></div></div></Section>
 <Section tone="cream" eyebrow="Golf near Cedar Ridge" title="Public golf with a local rhythm." intro="Cedar Ridge Golf Club serves daily-fee players, league golfers, families, and groups throughout the Cedar Ridge area. Four tees, clear rates, practice options, and a full clubhouse make planning a round simple."><a class="font-bold text-fairway underline decoration-gold underline-offset-4" href="/guides/best-public-golf-near-cedar-ridge">Read our local golf guide →</a></Section>
 <CTASection title="Ready when you are." body={`${business.address.street}, ${business.address.city} · Call ${business.phone} for course conditions or same-day availability.`} primaryLabel="Book a tee time" primaryHref={business.bookingUrl} secondaryLabel="Directions" secondaryHref={business.directionsUrl}/>
</BaseLayout>
