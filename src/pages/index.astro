---
import BaseLayout from "../layouts/BaseLayout.astro";
import CourseStatusBanner from "../components/ui/CourseStatusBanner.astro";
import CTASection from "../components/ui/CTASection.astro";
import FeatureCard from "../components/ui/FeatureCard.astro";
import LocalSeoBlock from "../components/ui/LocalSeoBlock.astro";
import Section from "../components/ui/Section.astro";
import StatGrid from "../components/ui/StatGrid.astro";
import { course } from "../data/course";
import { home } from "../data/home";
import { pageSeo } from "../data/seo";
---

<BaseLayout {...pageSeo.home}>
  <section
    class="relative overflow-hidden bg-forest px-6 py-16 text-white md:py-32"
  >
    <div class="topo absolute inset-0 opacity-50" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl">
      <p class="eyebrow text-gold">{home.hero.eyebrow}</p>
      <h1 class="mt-5 max-w-4xl text-6xl leading-[0.98] text-white md:text-8xl">
        {home.hero.title}
      </h1>
      <p class="mt-7 max-w-2xl text-xl leading-8 text-white/70">
        {home.hero.intro}
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="btn-primary" href={home.hero.primaryCta.href}
          >{home.hero.primaryCta.label}</a
        >
        <a
          class="btn border border-white/50 text-white hover:bg-white hover:text-forest"
          href={home.hero.secondaryCta.href}
        >
          {home.hero.secondaryCta.label}
        </a>
      </div>
    </div>
  </section>

  <CourseStatusBanner />

  <Section {...home.quickSection}>
    <div
      class="grid gap-px overflow-hidden rounded-2xl bg-forest/10 md:grid-cols-2 xl:grid-cols-4"
    >
      {home.quickCards.map((card) => <FeatureCard {...card} />)}
    </div>
  </Section>

  <Section tone="green" eyebrow={home.stats.eyebrow} title={home.stats.title}>
    <StatGrid stats={course.stats} dark />
  </Section>

  <Section tone="cream" {...home.outings}>
    <a class="btn-primary" href={home.outings.cta.href}
      >{home.outings.cta.label}</a
    >
  </Section>

  <Section {...home.clubhouse}>
    <div class="grid gap-6 md:grid-cols-[1.4fr_.6fr]">
      <div class="topo min-h-72 rounded-2xl bg-forest p-8 text-white">
        <p class="eyebrow text-gold">{home.clubhouse.featureLabel}</p>
        <p class="mt-6 max-w-md font-serif text-4xl">
          {home.clubhouse.feature}
        </p>
      </div>
      <div class="surface flex flex-col justify-between p-8">
        <div>
          <p class="eyebrow">{home.clubhouse.hoursLabel}</p>
          <p class="mt-5 whitespace-pre-line text-2xl font-semibold">
            {home.clubhouse.hours}
          </p>
        </div>
        <a class="btn-secondary mt-8" href="/menu">View the menu</a>
      </div>
    </div>
  </Section>

  <LocalSeoBlock />

  <CTASection
    title={home.finalCta.title}
    body={home.finalCta.body}
    primaryLabel="Book a tee time"
    primaryHref={home.hero.primaryCta.href}
    secondaryLabel="Directions"
    secondaryHref="/contact"
  />
</BaseLayout>
