---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageHero from '../components/ui/PageHero.astro'; import Breadcrumbs from '../components/ui/Breadcrumbs.astro'; import Section from '../components/ui/Section.astro'; import FAQBlock from '../components/ui/FAQBlock.astro'; import MembershipCards from '../components/golf/MembershipCards.astro'; import {pageSeo} from '../data/seo'; import {business} from '../data/business';
const faqs=[{question:'Are cart fees included?',answer:'Season cart plans are available separately. Daily cart fees apply unless a cart plan is added.'},{question:'Can I pay in installments?',answer:'A two-payment option is available when the first payment is made before the season.'},{question:'Do memberships renew automatically?',answer:'No. Members receive renewal information each year and choose whether to continue.'},{question:'Are memberships transferable?',answer:'Memberships are assigned to the named player and cannot be transferred.'}];
---
<BaseLayout {...pageSeo.memberships}><Breadcrumbs items={[{label:'Home',href:'/'},{label:'Memberships'}]}/><PageHero eyebrow="Memberships" title="Play more. Plan less." intro="Straightforward seasonal options for golfers who want regular access, familiar faces, and a little more flexibility."><a class="btn-primary" href="#interest">Compare options</a></PageHero><Section id="interest" eyebrow="2026 memberships" title="Choose how you play."><MembershipCards/><p class="mt-5 text-sm text-charcoal/60">Prices are sample content and should be updated before launch.</p></Section><Section tone="green" eyebrow="Member benefits" title="More than a lower per-round cost."><div class="grid gap-6 md:grid-cols-3">{['Earlier booking','A golf routine','A club connection'].map((t,i)=><div class="border-t border-white/20 pt-5"><h3 class="text-2xl text-white">{t}</h3><p class="mt-3 text-sm leading-6 text-white/65">{['Plan the times that work for your schedule.','Make regular golf easier to put on the calendar.','Join events, leagues, and a familiar local group.'][i]}</p></div>)}</div></Section><Section eyebrow="Membership FAQ" title="A few details before you join."><FAQBlock items={faqs}/><a class="btn-primary mt-8" href={`mailto:${business.email}?subject=Membership interest`}>Email membership interest</a></Section></BaseLayout>
