---
import BaseLayout from "../layouts/BaseLayout.astro";
import MembershipCards from "../components/golf/MembershipCards.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import FAQBlock from "../components/ui/FAQBlock.astro";
import PageHero from "../components/ui/PageHero.astro";
import Section from "../components/ui/Section.astro";
import { business } from "../data/business";
import {
  membershipBenefits,
  membershipDisclaimer,
  membershipFaqs,
} from "../data/memberships";
import { pageSeo } from "../data/seo";
import { faqSchema } from "../utils/schema";
---

<BaseLayout {...pageSeo.memberships} schemas={[faqSchema(membershipFaqs)]}>
  <Breadcrumbs
    items={[{ label: "Home", href: "/" }, { label: "Memberships" }]}
  />
  <PageHero
    eyebrow="Memberships"
    title="Play more. Plan less."
    intro="Straightforward seasonal options for golfers who want regular access, familiar faces, and a little more flexibility."
  >
    <a class="btn-primary" href="#options">Compare options</a>
  </PageHero>
  <Section id="options" eyebrow="2026 memberships" title="Choose how you play.">
    <MembershipCards />
    <p class="mt-5 text-sm text-charcoal/60">{membershipDisclaimer}</p>
  </Section>
  <Section
    tone="green"
    eyebrow="Member benefits"
    title="More than a lower per-round cost."
  >
    <div class="grid gap-6 md:grid-cols-3">
      {
        membershipBenefits.map((benefit) => (
          <div class="border-t border-white/20 pt-5">
            <h3 class="text-2xl text-white">{benefit.title}</h3>
            <p class="mt-3 text-sm leading-6 text-white/65">{benefit.body}</p>
          </div>
        ))
      }
    </div>
  </Section>
  <Section eyebrow="Membership FAQ" title="A few details before you join.">
    <FAQBlock items={membershipFaqs} />
    <a
      class="btn-primary mt-8"
      href={`mailto:${business.email}?subject=Membership interest`}
    >
      Email membership interest
    </a>
  </Section>
</BaseLayout>
