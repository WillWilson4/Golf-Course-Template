---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import PageHero from "../../components/ui/PageHero.astro";
import Section from "../../components/ui/Section.astro";
import { pageSeo } from "../../data/seo";
import { guideIndexContent } from "../../data/pageContent";
import { business } from "../../data/business";

const guides = (await getCollection("guides")).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf(),
);
---

<BaseLayout {...pageSeo.guides}>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Guides" }]} />
  <PageHero {...guideIndexContent.hero}>
    <a class="btn-primary" href={business.bookingUrl}>Book a tee time</a>
    <a class="btn-secondary" href="/tee-times#rates">View rates</a>
  </PageHero>
  <Section {...guideIndexContent.section}>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        guides.map((guide) => (
          <article class="surface flex flex-col p-7">
            <p class="eyebrow">{guide.data.eyebrow}</p>
            <h2 class="mt-8 text-3xl">
              <a href={`/guides/${guide.id}`}>{guide.data.title}</a>
            </h2>
            <p class="mt-3 leading-7 text-charcoal/65">
              {guide.data.description}
            </p>
            <a
              class="mt-auto pt-7 font-bold text-fairway"
              href={`/guides/${guide.id}`}
            >
              Read guide <span aria-hidden="true">→</span>
            </a>
          </article>
        ))
      }
    </div>
  </Section>
</BaseLayout>
