---
interface Props {
  title: string;
  body: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}
const p = Astro.props;
---

<section class="px-4 py-14 sm:px-6 sm:py-16">
  <div
    class="topo mx-auto flex max-w-7xl flex-col gap-8 rounded-3xl bg-forest p-7 text-white shadow-[0_22px_60px_rgba(18,60,45,0.16)] sm:p-9 md:flex-row md:items-center md:justify-between md:p-14"
  >
    <div>
      <h2 class="text-3xl leading-tight text-white md:text-4xl">{p.title}</h2><p
        class="mt-3 max-w-2xl leading-7 text-white/75"
      >
        {p.body}
      </p>
    </div><div class="grid shrink-0 gap-3 sm:flex sm:flex-wrap">
      <a class="btn-primary w-full sm:w-auto" href={p.primaryHref}
        >{p.primaryLabel}</a
      >{
        p.secondaryLabel && (
          <a
            class="btn w-full border border-white/50 text-white hover:bg-white hover:text-forest sm:w-auto"
            href={p.secondaryHref}
          >
            {p.secondaryLabel}
          </a>
        )
      }
    </div>
  </div>
</section>
