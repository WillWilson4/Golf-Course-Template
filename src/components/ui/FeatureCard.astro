---
interface Props {
  title: string;
  body: string;
  href: string;
  number?: string;
  actionLabel?: string;
}

const { title, body, href, number, actionLabel = "Explore" } = Astro.props;
---

<a
  href={href}
  class="group flex min-h-64 flex-col bg-white p-6 transition-colors hover:bg-cream sm:p-7"
>
  {number && <span class="text-xs font-bold text-gold">{number}</span>}
  <h3 class="mt-9 text-2xl">{title}</h3>
  <p class="mt-3 text-sm leading-6 text-charcoal/65">{body}</p>
  <span
    class="mt-auto inline-block pt-6 font-bold text-fairway transition-transform group-hover:translate-x-1"
  >
    {actionLabel}
    <span aria-hidden="true">&rarr;</span>
  </span>
</a>
