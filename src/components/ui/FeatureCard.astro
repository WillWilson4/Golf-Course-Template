---
interface Props {
  title: string;
  body: string;
  href: string;
  number?: string;
}

const { title, body, href, number } = Astro.props;
---

<a href={href} class="group bg-white p-7 hover:bg-cream">
  {number && <span class="text-xs font-bold text-gold">{number}</span>}
  <h3 class="mt-12 text-2xl">{title}</h3>
  <p class="mt-3 text-sm leading-6 text-charcoal/65">{body}</p>
  <span
    class="mt-6 inline-block font-bold text-fairway transition-transform group-hover:translate-x-1"
  >
    Explore <span aria-hidden="true">→</span>
  </span>
</a>
