---
interface Props{items:{label:string;href?:string}[]} const {items}=Astro.props;
---
<nav class="mx-auto max-w-7xl px-6 py-4 text-sm text-charcoal/60" aria-label="Breadcrumb"><ol class="flex flex-wrap gap-2">{items.map((item,i)=><li class="flex gap-2">{i>0&&<span aria-hidden="true">/</span>}{item.href?<a class="hover:text-forest" href={item.href}>{item.label}</a>:<span aria-current="page">{item.label}</span>}</li>)}</ol></nav>
