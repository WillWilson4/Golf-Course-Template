---
interface Props {
  activity: { title: string; description: string; meta: string };
  index: number;
}

const { activity, index } = Astro.props;
---

<article class="surface flex min-h-64 flex-col p-7">
  <p class="eyebrow">{String(index + 1).padStart(2, "0")}</p>
  <h3 class="mt-8 text-3xl">{activity.title}</h3>
  <p class="mt-3 leading-7 text-charcoal/65">{activity.description}</p>
  <p class="mt-auto pt-8 text-sm font-bold text-fairway">{activity.meta}</p>
</article>
