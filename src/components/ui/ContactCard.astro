---
import { business } from "../../data/business";

interface Props {
  variant: "address" | "contact";
}

const { variant } = Astro.props;
---

<article class="surface p-7">
  {
    variant === "address" ? (
      <>
        <p class="eyebrow">Address</p>
        <address class="mt-6 not-italic leading-7">
          {business.address.street}
          <br />
          {business.address.city}, {business.address.region}{" "}
          {business.address.postalCode}
        </address>
        <a
          class="mt-6 inline-block font-bold text-fairway"
          href={business.directionsUrl}
        >
          Open directions <span aria-hidden="true">→</span>
        </a>
      </>
    ) : (
      <>
        <p class="eyebrow">Contact</p>
        <p class="mt-6 leading-8">
          <>
            <a href={business.phoneHref}>{business.phone}</a>
            <br />
          </>
          <a href={`mailto:${business.email}`}>{business.email}</a>
        </p>
      </>
    )
  }
</article>
