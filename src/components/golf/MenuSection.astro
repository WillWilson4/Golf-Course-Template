---
interface Props {
  section: {
    title: string;
    items: readonly { name: string; description: string; price: string }[];
  };
}
const { section } = Astro.props;
---

<section class="surface h-full p-6 sm:p-7">
  <h2 class="text-3xl">{section.title}</h2><div
    class="mt-6 divide-y divide-forest/10"
  >
    {
      section.items.map((item) => (
        <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-4 py-5 first:pt-0 last:pb-0">
          <>
            <div>
              <>
                <h3 class="font-sans text-base font-bold">{item.name}</h3>
                <p class="mt-1 text-sm leading-6 text-charcoal/65">
                  {item.description}
                </p>
              </>
            </div>
            <p class="whitespace-nowrap font-semibold text-fairway">
              {item.price}
            </p>
          </>
        </div>
      ))
    }
  </div>
</section>
