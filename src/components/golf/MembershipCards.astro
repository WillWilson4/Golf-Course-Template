---
import {memberships} from '../../data/memberships';
---
<div class="grid gap-6 md:grid-cols-3">{memberships.map(plan=><article class:list={['surface relative p-7',plan.featured&&'border-gold ring-2 ring-gold']} >{plan.featured&&<span class="absolute -top-3 rounded-full bg-gold px-3 py-1 text-xs font-bold">Most flexible</span>}<h3 class="text-2xl">{plan.name}</h3><p class="mt-5 font-serif text-4xl text-forest">{plan.price}<span class="font-sans text-sm text-charcoal/60"> / season</span></p><p class="mt-2 text-sm text-charcoal/60">{plan.detail}</p><ul class="mt-6 space-y-3 text-sm">{plan.benefits.map(b=><li class="flex gap-2"><span class="text-gold">◆</span>{b}</li>)}</ul></article>)}</div>
