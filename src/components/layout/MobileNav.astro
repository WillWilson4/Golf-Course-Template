---
import { navigation } from "../../data/navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<details class="group relative xl:hidden" data-mobile-nav>
  <summary
    class="flex min-h-10 cursor-pointer list-none items-center gap-2 rounded-full border border-white/35 px-4 py-2 text-sm font-bold marker:hidden hover:border-gold hover:text-gold"
    aria-label="Toggle navigation menu"
    aria-expanded="false"
  >
    <span class="grid gap-1" aria-hidden="true">
      <span class="block h-px w-3.5 bg-current"></span>
      <span class="block h-px w-3.5 bg-current"></span>
      <span class="block h-px w-3.5 bg-current"></span>
    </span>
    <span>Menu</span>
  </summary>
  <nav
    class="absolute right-0 top-14 z-50 grid w-[min(20rem,calc(100vw-2rem))] grid-cols-2 gap-1 rounded-2xl border border-forest/10 bg-white p-3 text-charcoal shadow-2xl"
    aria-label="Mobile navigation"
  >
    {
      navigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            "flex min-h-12 items-center rounded-xl px-4 py-3 text-sm font-semibold hover:bg-mist",
            currentPath.startsWith(item.href) && "bg-cream text-forest",
          ]}
          aria-current={currentPath.startsWith(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</details>

<script is:inline>
  (() => {
    const navigation = document.querySelector("[data-mobile-nav]");
    const trigger = navigation?.querySelector("summary");
    if (
      !(navigation instanceof HTMLDetailsElement) ||
      !(trigger instanceof HTMLElement)
    )
      return;

    const syncState = () =>
      trigger.setAttribute("aria-expanded", String(navigation.open));
    navigation.addEventListener("toggle", syncState);
    navigation.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && navigation.open) {
        navigation.open = false;
        trigger.focus();
      }
    });
    document.addEventListener("click", (event) => {
      if (
        navigation.open &&
        event.target instanceof Node &&
        !navigation.contains(event.target)
      ) {
        navigation.open = false;
      }
    });
    syncState();
  })();
</script>
