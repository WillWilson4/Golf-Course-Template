---
import { navigation } from "../../data/navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<details class="group relative xl:hidden">
  <summary
    class="flex min-h-10 cursor-pointer list-none items-center rounded-full border border-white/35 px-4 py-2 text-sm font-bold marker:hidden hover:border-gold hover:text-gold"
    aria-label="Open navigation menu"
  >
    Menu
  </summary>
  <nav
    class="absolute right-0 top-14 z-50 grid w-[min(19rem,calc(100vw-2rem))] grid-cols-2 gap-1 rounded-2xl border border-forest/10 bg-white p-3 text-charcoal shadow-2xl"
    aria-label="Mobile navigation"
  >
    {
      navigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            "rounded-xl px-4 py-3 text-sm font-semibold hover:bg-mist",
            currentPath.startsWith(item.href) && "bg-cream text-forest",
          ]}
          aria-current={currentPath.startsWith(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</details>
