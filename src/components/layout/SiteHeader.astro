---
import { business } from "../../data/business";
import { navigation } from "../../data/navigation";
import { siteSettings } from "../../data/siteSettings";
import MobileNav from "./MobileNav.astro";

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-white/10 bg-forest text-white shadow-[0_6px_24px_rgba(18,60,45,0.12)]"
>
  <div
    class="mx-auto flex h-16 max-w-7xl items-center gap-3 px-4 sm:h-18 sm:px-6"
  >
    <a
      href="/"
      class="mr-auto flex min-w-0 items-center gap-3 rounded-full"
      aria-label={`${business.name} home`}
    >
      <span
        class="grid size-10 shrink-0 place-items-center rounded-full border border-gold/60 font-serif text-lg text-gold"
        aria-hidden="true"
      >
        CR
      </span>
      <span
        class="hidden truncate font-serif text-lg font-semibold leading-tight sm:block"
      >
        {business.name}
      </span>
    </a>

    <nav
      class="hidden items-center gap-5 xl:flex"
      aria-label="Primary navigation"
    >
      {
        navigation.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-sm hover:text-gold",
              currentPath.startsWith(item.href) && "text-gold",
            ]}
            aria-current={
              currentPath.startsWith(item.href) ? "page" : undefined
            }
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href={business.phoneHref}
      class="inline-flex min-h-10 items-center px-1 text-sm font-bold text-gold sm:hidden"
    >
      {siteSettings.callLabel}
    </a>
    <a href={business.bookingUrl} class="btn-primary min-h-10 px-4 py-2">
      <span class="sm:hidden">Book</span>
      <span class="hidden sm:inline">{siteSettings.bookingLabel}</span>
    </a>
    <MobileNav currentPath={currentPath} />
  </div>
</header>
