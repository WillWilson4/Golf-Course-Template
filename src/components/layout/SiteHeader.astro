---
import { business } from '../../data/business'; import { navigation } from '../../data/navigation';
const current=Astro.url.pathname;
---
<header class="sticky top-0 z-50 border-b border-white/10 bg-forest text-white">
 <div class="mx-auto flex h-18 max-w-7xl items-center gap-4 px-4 sm:px-6">
  <a href="/" class="mr-auto flex items-center gap-3" aria-label={`${business.name} home`}><span class="grid size-10 place-items-center rounded-full border border-gold/60 font-serif text-lg text-gold">CR</span><span class="hidden font-serif text-lg font-semibold leading-tight sm:block">{business.name}</span></a>
  <nav class="hidden items-center gap-5 xl:flex" aria-label="Primary navigation">{navigation.map(item=><a href={item.href} class:list={['text-sm hover:text-gold',current.startsWith(item.href)&&'text-gold']}>{item.label}</a>)}</nav>
  <a href={business.phoneHref} class="text-sm font-bold text-gold sm:hidden">Call</a><a href={business.bookingUrl} class="btn-primary min-h-10 px-4 py-2">Book <span class="hidden sm:inline">tee time</span></a>
  <details class="relative xl:hidden"><summary class="cursor-pointer list-none rounded-full border border-white/30 px-4 py-2 text-sm font-bold">Menu</summary><nav class="absolute right-0 top-14 grid w-64 rounded-xl bg-white p-3 text-charcoal shadow-2xl" aria-label="Mobile navigation">{navigation.map(item=><a href={item.href} class="rounded-lg px-4 py-3 hover:bg-mist">{item.label}</a>)}</nav></details>
 </div>
</header>
