---
import { business } from "../../data/business";
import { navigation } from "../../data/navigation";
import { siteSettings } from "../../data/siteSettings";
import SocialLinks from "../ui/SocialLinks.astro";
---

<footer class="bg-charcoal text-white">
  <div class="border-b border-white/10 bg-forest/35">
    <div
      class="mx-auto flex max-w-7xl flex-col gap-5 px-6 py-8 sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <p class="font-serif text-2xl text-cream">Ready for your next round?</p>
        <p class="mt-1 text-sm text-white/65">
          Book online or call the golf shop for same-day help.
        </p>
      </div>
      <div class="grid gap-3 sm:flex">
        <a class="btn-primary w-full sm:w-auto" href={business.bookingUrl}
          >Book a tee time</a
        >
        <a
          class="btn border border-white/40 text-white hover:bg-white hover:text-forest"
          href={business.phoneHref}
        >
          Call {business.phone}
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto grid max-w-7xl gap-10 px-6 py-12 md:grid-cols-3 md:py-14">
    <div>
      <p class="font-serif text-2xl text-cream">{business.name}</p>
      <p class="mt-3 max-w-sm text-sm leading-6 text-white/70">
        {business.tagline}
      </p>
      <div class="mt-5"><SocialLinks /></div>
    </div>
    <div>
      <p class="eyebrow text-gold">Explore</p>
      <nav
        class="mt-3 grid grid-cols-2 gap-x-4 text-sm"
        aria-label="Footer navigation"
      >
        {
          navigation.map((item) => (
            <a
              class="flex min-h-11 items-center text-white/70 hover:text-white"
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
    <div>
      <p class="eyebrow text-gold">Visit</p>
      <address class="mt-4 text-sm not-italic leading-7 text-white/70">
        {business.address.street}<br />
        {
          `${business.address.city}, ${business.address.region} ${business.address.postalCode}`
        }<br />
        <a
          class="inline-flex min-h-10 items-center hover:text-white"
          href={business.phoneHref}>{business.phone}</a
        ><br />
        <a
          class="inline-flex min-h-10 items-center hover:text-white"
          href={`mailto:${business.email}`}>{business.email}</a
        >
      </address>
    </div>
  </div>
  <div class="border-t border-white/10 px-6 py-5">
    <div
      class="mx-auto flex max-w-7xl flex-col gap-3 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>
        &copy; {new Date().getFullYear()}
        {business.name}. All rights reserved.
      </p>
      <nav class="flex flex-wrap gap-x-5" aria-label="Legal">
        {
          siteSettings.footerUtilityLinks.map((item) => (
            <a
              class="inline-flex min-h-10 items-center hover:text-white"
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</footer>
