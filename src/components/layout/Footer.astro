---
import { business } from "../../data/business";
import { navigation } from "../../data/navigation";
import { siteSettings } from "../../data/siteSettings";
import SocialLinks from "../ui/SocialLinks.astro";
---

<footer class="bg-charcoal text-white">
  <div class="mx-auto grid max-w-7xl gap-10 px-6 py-14 md:grid-cols-3">
    <div>
      <p class="font-serif text-2xl text-cream">{business.name}</p>
      <p class="mt-3 max-w-sm text-sm leading-6 text-white/65">
        {business.tagline}
      </p>
      <div class="mt-5"><SocialLinks /></div>
    </div>
    <div>
      <p class="eyebrow text-gold">Explore</p>
      <nav
        class="mt-4 grid grid-cols-2 gap-3 text-sm"
        aria-label="Footer navigation"
      >
        {
          navigation.map((item) => (
            <a class="text-white/70 hover:text-white" href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
    <div>
      <p class="eyebrow text-gold">Visit</p>
      <address class="mt-4 text-sm not-italic leading-7 text-white/70">
        {business.address.street}<br />
        {business.address.city}, {business.address.region}
        {business.address.postalCode}<br />
        <a href={business.phoneHref}>{business.phone}</a><br />
        <a href={`mailto:${business.email}`}>{business.email}</a>
      </address>
    </div>
  </div>
  <div class="border-t border-white/10 px-6 py-5">
    <div
      class="mx-auto flex max-w-7xl flex-wrap justify-between gap-3 text-xs text-white/45"
    >
      <p>© {new Date().getFullYear()} {business.name}. All rights reserved.</p>
      <nav class="flex gap-4" aria-label="Legal">
        {
          siteSettings.footerUtilityLinks.map((item) => (
            <a class="hover:text-white" href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</footer>
